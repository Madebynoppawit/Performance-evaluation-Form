# Production environment for docker-compose.prod.yml
# Copy to .env.prod and fill in real values. NEVER commit .env.prod.
#
#   cp .env.prod.example .env.prod
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build

# ── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=amw
POSTGRES_PASSWORD=                 # REQUIRED — strong random password
POSTGRES_DB=performance_eval

# ── Auth / API ──────────────────────────────────────────────────────────────
# REQUIRED — 32+ char random secret. Generate:  openssl rand -base64 48
JWT_SECRET=
JWT_EXPIRES_IN=12h
COMPANY_EMAIL_DOMAIN=amw-ems.com

# Public URL the browser loads the app from (used for the CORS allowlist).
# REQUIRED in production — wildcard "*" is rejected.
CLIENT_URL=https://eval.example.com
# Optional extra allowed origins (comma-separated). Leave blank if not needed.
CORS_ORIGINS=

# ── Frontend exposure ───────────────────────────────────────────────────────
# Host port that serves the app (put a TLS-terminating reverse proxy in front).
HTTP_PORT=8080

# ── Email / SMTP ────────────────────────────────────────────────────────────
# Transactional email: evaluation-assigned, pending-review, acknowledge, etc.
# Leave blank to disable email (notifications fall back to in-app only).
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false              # true for port 465 (TLS); false for STARTTLS
SMTP_USER=noreply@amw-ems.com
SMTP_PASS=                     # REQUIRED when SMTP_HOST is set
SMTP_FROM="AMW Evaluations <noreply@amw-ems.com>"

# ── Observability (optional) ────────────────────────────────────────────────
LOG_LEVEL=info
SENTRY_DSN=
# Prometheus metrics are exposed at GET /metrics. If set, scrapers must send
# `Authorization: Bearer <token>`; if unset, restrict /metrics at the network.
METRICS_TOKEN=

# Backup / restore
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
BACKUP_DIR=/opt/amw/backups
BACKUP_KEEP_DAYS=30
BACKUP_S3_BUCKET=

# ── Seeding ─────────────────────────────────────────────────────────────────
# The demo seed (admin@amw-ems.com / P@ssw0rd!) refuses to run in production.
# To force it once (NOT recommended), run the migrate/backend image with:
#   NODE_ENV=production ALLOW_PROD_SEED=true npm run db:seed -w backend
