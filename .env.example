###############################################################################
# AMW Command — Backend environment
#
# Setup:  cp .env.example backend/.env   then fill in real values.
# All variables are validated at startup (backend/src/config/env.ts).
# The server refuses to boot on invalid config and fails fast with a clear list.
###############################################################################

# ── Runtime ──────────────────────────────────────────────────────────────────
# One of: development | test | production
NODE_ENV=development
# Port the API listens on
PORT=3001
# Log verbosity: debug | info | warn | error
LOG_LEVEL=info

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string. For local Docker (docker-compose.yml):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/performance_eval"

# ── Authentication ───────────────────────────────────────────────────────────
# JWT signing secret. MUST be a random string >= 32 chars in production —
# the server refuses to start in production with a weak/placeholder value.
# Generate one:  openssl rand -base64 48
JWT_SECRET="change-this-to-a-random-secret-key"
# Token lifetime (zeit/ms format): 15m | 12h | 7d | 30d
JWT_EXPIRES_IN="7d"
# bcrypt cost factor for password hashing (8-15; higher = slower & safer)
BCRYPT_ROUNDS=10

# ── CORS ─────────────────────────────────────────────────────────────────────
# Single frontend origin (used if CORS_ORIGINS is empty):
CLIENT_URL="http://localhost:5173"
# Optional comma-separated allowlist (overrides CLIENT_URL); e.g.:
# CORS_ORIGINS="https://app.amw.com,https://admin.amw.com"
# CORS_ORIGINS=

# ── Rate limiting (auth endpoints) ───────────────────────────────────────────
# Window length in milliseconds (default 15 min) and max requests per window.
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=20
