###############################################################################
# AMW Command — Frontend environment (Vite)
#
# Setup:  cp frontend/.env.example frontend/.env.local
# Only variables prefixed with VITE_ are exposed to the browser bundle.
# NEVER put secrets here — everything here ships to the client.
###############################################################################

# API base URL. Leave empty in development to use the Vite dev proxy ("/api").
# In production set it to your API origin, e.g. https://api.amw.com
VITE_API_BASE_URL=

# Branding
VITE_APP_NAME="AMW Command"
VITE_APP_VERSION="0.1.0"

# Error monitoring — set to your Sentry DSN to activate (leave empty = off)
VITE_SENTRY_DSN=
