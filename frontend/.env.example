###############################################################################
# AMW Command — Frontend environment (Vite)
#
# Setup:  cp frontend/.env.example frontend/.env.local
# Only variables prefixed with VITE_ are exposed to the browser bundle.
# NEVER put secrets here — everything here ships to the client.
###############################################################################

# API base URL. Leave empty in development to use the Vite dev proxy ("/api").
# In production set it to your API origin, e.g. https://api.amw.com
VITE_API_BASE_URL=

# Branding
VITE_APP_NAME="AMW Command"
VITE_APP_VERSION="0.2.0-rc.1"

# Release flavor.
# Standard is the default no-AI build. For the AI trial build, set:
# VITE_RELEASE_CHANNEL=ai-preview
# VITE_ENABLE_AI_FEATURES=true
# VITE_AI_PROVIDER=openai or azure-openai
VITE_RELEASE_CHANNEL=standard
VITE_ENABLE_AI_FEATURES=false
VITE_AI_PROVIDER=none

# Deployment environment label shown in the governance bar: PROD | UAT | DEV
# (omit to auto-infer: production build -> PROD, otherwise DEV)
VITE_APP_ENV=

# Error monitoring — set to your Sentry DSN to activate (leave empty = off)
VITE_SENTRY_DSN=
