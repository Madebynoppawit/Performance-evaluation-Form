# Optional overrides for docker-compose.demo.yml.
# The demo compose file has safe defaults, so this file is only needed when
# changing ports, public URL, or demo passwords.

DEMO_POSTGRES_USER=amw_demo
DEMO_POSTGRES_PASSWORD=amw-demo-postgres-password-safe-for-local-demo
DEMO_POSTGRES_DB=performance_eval_demo

DEMO_JWT_SECRET=demo-only-jwt-secret-for-local-deploy-preview-123456
DEMO_JWT_EXPIRES_IN=12h
DEMO_CLIENT_URL=http://localhost:8080
DEMO_CORS_ORIGINS=http://localhost:8080
DEMO_HTTP_PORT=8080

DEMO_VITE_APP_VERSION=0.2.0-demo.1
DEMO_METRICS_TOKEN=demo-metrics-token-safe-for-local-demo
