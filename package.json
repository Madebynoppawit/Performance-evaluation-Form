{
  "name": "performance-evaluation-form",
  "version": "1.4.4",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w backend\" \"npm run dev -w frontend\"",
    "build": "npm run build -w backend && npm run build -w frontend",
    "lint": "npm run lint -w backend && npm run lint -w frontend",
    "test": "npm run test -w backend && npm run test -w frontend",
    "test:integration": "npm run test:integration -w backend",
    "test:integration:setup": "npm run test:integration:setup -w backend",
    "test:e2e": "npm run test:e2e -w frontend",
    "screenshots:readme": "node scripts/capture-readme-screenshots.mjs",
    "verify": "npm run lint && npm test && npm run test:e2e && npm run build && npm audit --audit-level=high",
    "db:migrate": "npm run db:migrate -w backend",
    "db:deploy": "npm run db:deploy -w backend",
    "db:seed": "npm run db:seed -w backend",
    "db:studio": "npm run db:studio -w backend",
    "qa": "node scripts/qa-robot/index.js",
    "qa:watch": "node scripts/qa-robot/index.js --watch",
    "qa:auth": "node scripts/qa-robot/index.js --suite auth",
    "qa:mobile": "node scripts/qa-robot/index.js --suite mobile"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  },
  "allowScripts": {
    "@prisma/client@5.22.0": true,
    "@prisma/engines@5.22.0": true,
    "prisma@5.22.0": true
  }
}
