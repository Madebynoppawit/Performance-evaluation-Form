# Normalize line endings: store as LF in the repo, check out native on Windows.
* text=auto eol=lf

# Scripts that must stay LF even on Windows checkouts
*.sh   text eol=lf

# Binary assets — never normalize
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pdf  binary
*.woff binary
*.woff2 binary
