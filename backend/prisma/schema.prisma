generator client {
  provider      = "prisma-client-js"
  // "native" for local dev; the debian target is for the Docker image
  // (node:20-bookworm-slim → OpenSSL 3.0).
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  DEVELOPER
  ADMIN
  MANAGER
  MANAGING_DIRECTOR
  DIRECTOR
  SUPERVISOR
  EMPLOYEE
  STAFF
  OPERATOR
}

enum Position {
  CEO
  MANAGING_DIRECTOR
  DIRECTOR_UP
  MANAGER
  OFFICER
  SUPERVISOR
  PRODUCTION_STAFF
  OTHER
}

enum EvaluationType {
  SELF
  MANAGER
  PEER
  THREE_SIXTY
}

enum EvaluationStatus {
  DRAFT
  IN_PROGRESS
  PENDING_REVIEW
  SUBMITTED
  REVIEWED
  CLOSED
}

enum CycleStatus {
  UPCOMING
  ACTIVE
  CLOSED
}

enum FormType {
  DIRECTOR_LEVEL
  MANAGER_LEVEL
  OFFICER_LEVEL
  SUPERVISOR_LEVEL
  PRODUCTION_LEVEL
}

enum EvaluationReason {
  PROBATION
  ANNUAL
  OTHER
}

enum PerformanceGrade {
  EXCELLENT
  ABOVE_STANDARD
  MEETS_STANDARD
  ALMOST_STANDARD
  BELOW_STANDARD
}

model User {
  id         String    @id @default(cuid())
  email      String    @unique
  name       String
  password   String
  role       Role      @default(EMPLOYEE)
  position   Position?
  department String?
  managerId  String?
  hireDate   DateTime?
  jobTitle   String?

  // Employee master-file key + the full raw imported row (nothing is dropped).
  employeeNo String? @unique
  sourceData Json?

  // Forces a password change on next login (set for default-password imports).
  mustChangePassword Boolean   @default(false)
  dateOfBirth        DateTime?

  manager   User?  @relation("ManagerEmployee", fields: [managerId], references: [id])
  employees User[] @relation("ManagerEmployee")

  evaluationsAsEvaluatee Evaluation[] @relation("Evaluatee")
  evaluationsAsEvaluator Evaluation[] @relation("Evaluator")
  evaluationsAsReviewer  Evaluation[] @relation("Reviewer")
  auditEvents             AuditEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditEvent {
  id          String   @id @default(cuid())
  eventType   String
  actorId     String?
  actorRole   Role?
  requestId   String?
  method      String?
  path        String?
  statusCode  Int?
  targetType  String?
  targetId    String?
  metadata    Json?
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([eventType, createdAt])
  @@index([actorId, createdAt])
  @@index([targetType, targetId])
  @@index([requestId])
}

model Template {
  id          String         @id @default(cuid())
  name        String
  description String?
  type        EvaluationType
  sections    Section[]
  cycles      Cycle[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Section {
  id          String     @id @default(cuid())
  templateId  String
  title       String
  description String?
  weight      Float      @default(1.0)
  order       Int
  template    Template   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  questions   Question[]
}

model Question {
  id        String   @id @default(cuid())
  sectionId String
  text      String
  type      String
  weight    Float    @default(1.0)
  options   Json?
  required  Boolean  @default(true)
  order     Int
  section   Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  answers   Answer[]
}

model Cycle {
  id          String      @id @default(cuid())
  name        String
  description String?
  templateId  String
  startDate   DateTime
  endDate     DateTime
  status      CycleStatus @default(UPCOMING)

  template    Template     @relation(fields: [templateId], references: [id])
  evaluations Evaluation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Evaluation {
  id          String           @id @default(cuid())
  cycleId     String
  evaluateeId String
  evaluatorId String
  type        EvaluationType
  status      EvaluationStatus @default(DRAFT)
  formType    FormType         @default(OFFICER_LEVEL)

  goalWeight       Float @default(70)
  competencyWeight Float @default(20)
  attendanceWeight Float @default(10)

  goalScore       Float?
  competencyScore Float?
  attendanceScore Float?
  totalScore      Float?
  submittedAt     DateTime?

  evaluateeName         String?
  evaluatorName         String?
  evaluationReason      EvaluationReason?
  evaluationReasonOther String?
  evaluatorTitle        String?
  performanceGrade      PerformanceGrade?
  effectiveDate         DateTime?

  // 2-stage workflow for Production Staff: supervisor evaluates first,
  // then reviewer (manager) does a second-pass review before final submission.
  reviewerId      String?
  reviewerName    String?
  reviewerComment String?
  reviewedAt      DateTime?

  cycle    Cycle  @relation(fields: [cycleId], references: [id])
  evaluatee User  @relation("Evaluatee",  fields: [evaluateeId], references: [id])
  evaluator User  @relation("Evaluator",  fields: [evaluatorId], references: [id])
  reviewer  User? @relation("Reviewer",   fields: [reviewerId],  references: [id])

  answers          Answer[]
  goalEntries      GoalEntry[]
  competencyScores CompetencyScore[]
  attendanceRecord AttendanceScore?
  trainingRecord   TrainingScore?
  comment          EvaluationComment?
  salarySummary    SalarySummary?
  acknowledgement  EvaluationAcknowledgement?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cycleId, evaluateeId, evaluatorId, type])
}

model Answer {
  id           String     @id @default(cuid())
  evaluationId String
  questionId   String
  value        String?
  score        Float?
  evaluation   Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  question     Question   @relation(fields: [questionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([evaluationId, questionId])
}

model GoalEntry {
  id           String     @id @default(cuid())
  evaluationId String
  evaluation   Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  goal            String
  goalDescription String?
  weight          Float   @default(20)

  targetRating5 String?
  targetRating4 String?
  targetRating3 String?
  targetRating2 String?
  targetRating1 String?

  wig          String?
  kpiCategory  String?

  result          String?
  evaluationScore Int?
  employeeComment String?
  superiorComment String?
  order           Int     @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([evaluationId])
}

model CompetencyScore {
  id           String     @id @default(cuid())
  evaluationId String
  evaluation   Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  competencyId String
  score        Int?

  @@unique([evaluationId, competencyId])
}

model AttendanceScore {
  id           String     @id @default(cuid())
  evaluationId String     @unique
  evaluation   Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  leaveActualDays   Int?
  lateActualTimes   Int?
  disciplinaryLevel String? @default("NONE")

  leaveScore        Int?
  lateScore         Int?
  disciplinaryScore Int?
  attendanceAvgScore Float?
}

model TrainingScore {
  id           String     @id @default(cuid())
  evaluationId String     @unique
  evaluation   Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  minimumHours     Float?
  actualHours      Float?
  percentOfMinimum Float?
  score            Int?
  behaviorNote     String?
}

model EvaluationComment {
  id           String     @id @default(cuid())
  evaluationId String     @unique
  evaluation   Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  strengths      String?
  improvements   String?
  requiredSkills String?
}

model SalarySummary {
  id           String     @id @default(cuid())
  evaluationId String     @unique
  evaluation   Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  oldSalary      Float?
  newSalary      Float?
  bonus          Float?
  bonusDeduction Float?
  bonusPolicy    String?
  effectiveDate  DateTime?
}

model EvaluationAcknowledgement {
  id           String     @id @default(cuid())
  evaluationId String     @unique
  evaluation   Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  employeeSignedAt  DateTime?
  evaluatorSignedAt DateTime?
  directorSignedAt  DateTime?
}

/// One row per employee-master import run. Stores the full raw file as a log
/// plus a per-row outcome summary, so nothing imported is ever lost.
model EmployeeImport {
  id           String   @id @default(cuid())
  filename     String?
  importedById String?
  totalRows    Int      @default(0)
  created      Int      @default(0)
  updated      Int      @default(0)
  failed       Int      @default(0)
  errors       Json?
  raw          String   @db.Text
  createdAt    DateTime @default(now())
}
