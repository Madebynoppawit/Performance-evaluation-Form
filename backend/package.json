{
  "name": "backend",
  "version": "1.4.6",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "lint": "tsc --noEmit",
    "test": "cross-env NODE_ENV=test tsx --test src/*/*.test.ts",
    "test:watch": "cross-env NODE_ENV=test tsx --test --watch src/*/*.test.ts",
    "test:integration": "cross-env NODE_ENV=test tsx --test src/routes/*.itest.ts src/integration/*.itest.ts",
    "test:integration:setup": "npm run db:test:deploy && npm run db:test:seed",
    "start": "node dist/index.js",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:test:deploy": "cross-env DATABASE_URL=postgresql://postgres:postgres@localhost:5432/amw_test prisma migrate deploy",
    "db:test:seed": "cross-env NODE_ENV=test DATABASE_URL=postgresql://postgres:postgres@localhost:5432/amw_test node prisma/seed.cjs",
    "db:seed": "node prisma/seed.cjs",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.7.1",
    "@sentry/node": "^10.56.0",
    "@types/nodemailer": "^8.0.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^9.0.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prisma": "^5.7.1",
    "prom-client": "^15.1.3",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.6",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "cross-env": "^10.1.0",
    "supertest": "^7.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
