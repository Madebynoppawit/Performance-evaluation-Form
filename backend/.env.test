# Committed test environment — dummy values, never used in dev or prod.
# Lets the unit suite boot config/env without a real .env (CI-safe).
# Tests are pure (no DB I/O), so the DATABASE_URL only needs to be well-formed.
NODE_ENV=test
PORT=3101
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/amw_test"
JWT_SECRET="test-secret-not-used-in-production-32chars-minimum-xx"
JWT_EXPIRES_IN="1h"
CLIENT_URL="http://localhost:5173"
LOG_LEVEL=error
